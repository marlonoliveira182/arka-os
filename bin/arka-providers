#!/usr/bin/env bash
# ============================================================================
# ARKA OS — Provider Registry Manager
# Manage external AI providers and models (image, video, text)
# Usage: arka providers [command] [args...]
# ============================================================================
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
REGISTRY="$REPO_DIR/config/providers-registry.json"
ENV_FILE="$HOME/.arka-os/.env"

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

# Require jq
command -v jq &>/dev/null || { echo "Error: jq is required. Install: brew install jq"; exit 1; }

# Load env if present
[ -f "$ENV_FILE" ] && source "$ENV_FILE"

# ─── Helper: Check if API key is configured ─────────────────────────────────
is_key_configured() {
  local var_name="$1"
  local value="${!var_name:-}"
  [ -n "$value" ] && [ ${#value} -ge 8 ]
}

# ─── List providers ──────────────────────────────────────────────────────────
cmd_list() {
  echo ""
  echo -e "${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
  echo -e "${CYAN}║${NC}  ${BOLD}ARKA OS — AI Providers${NC}                                     ${CYAN}║${NC}"
  echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}"
  echo ""

  local providers
  providers=$(jq -r '.providers | keys[]' "$REGISTRY")

  for provider_id in $providers; do
    local name auth_env
    name=$(jq -r --arg id "$provider_id" '.providers[$id].name' "$REGISTRY")
    auth_env=$(jq -r --arg id "$provider_id" '.providers[$id].auth_env' "$REGISTRY")

    if is_key_configured "$auth_env"; then
      echo -e "  ${GREEN}●${NC} ${BOLD}$name${NC} ($provider_id) — ${GREEN}configured${NC} [$auth_env]"
    else
      echo -e "  ${RED}○${NC} ${BOLD}$name${NC} ($provider_id) — ${YELLOW}not configured${NC} [$auth_env]"
    fi

    # List models
    local models
    models=$(jq -r --arg id "$provider_id" '.providers[$id].models | to_entries[] | "      \(.value.type | ascii_upcase)  \(.key) — \(.value.description)"' "$REGISTRY")
    echo "$models"
    echo ""
  done

  local total_providers total_models
  total_providers=$(jq '.providers | length' "$REGISTRY")
  total_models=$(jq '[.providers[].models | length] | add' "$REGISTRY")
  echo -e "  ${CYAN}$total_providers${NC} providers, ${CYAN}$total_models${NC} models"
  echo ""
}

# ─── Add provider (interactive) ─────────────────────────────────────────────
cmd_add() {
  local provider_id="${1:-}"
  if [ -z "$provider_id" ]; then
    echo -e "${BLUE}Add a new AI provider${NC}"
    read -rp "  Provider ID (lowercase, no spaces): " provider_id
  fi
  [ -z "$provider_id" ] && { echo "Error: Provider ID is required."; exit 1; }

  # Check if already exists
  if jq -e --arg id "$provider_id" '.providers[$id]' "$REGISTRY" &>/dev/null; then
    echo -e "${YELLOW}Provider '$provider_id' already exists. Use 'add-model' to add models.${NC}"
    exit 1
  fi

  read -rp "  Display name: " name
  read -rp "  Base URL (e.g., https://api.example.com/v1): " base_url
  read -rp "  Auth env variable name (e.g., EXAMPLE_API_KEY): " auth_env
  read -rp "  Auth header format (e.g., Authorization: Bearer): " auth_header

  [ -z "$name" ] || [ -z "$base_url" ] || [ -z "$auth_env" ] && { echo "Error: All fields are required."; exit 1; }
  [ -z "$auth_header" ] && auth_header="Authorization: Bearer"

  # Add to registry
  local tmp
  tmp=$(mktemp)
  jq --arg id "$provider_id" \
     --arg name "$name" \
     --arg base_url "$base_url" \
     --arg auth_env "$auth_env" \
     --arg auth_header "$auth_header" \
     '.providers[$id] = {name: $name, base_url: $base_url, auth_env: $auth_env, auth_header: $auth_header, models: {}}' \
     "$REGISTRY" > "$tmp" && mv "$tmp" "$REGISTRY"

  echo -e "${GREEN}✓${NC} Provider '$provider_id' added. Use 'arka providers add-model $provider_id <model-id>' to add models."
}

# ─── Remove provider ─────────────────────────────────────────────────────────
cmd_remove() {
  local provider_id="${1:-}"
  [ -z "$provider_id" ] && { echo "Usage: arka providers remove <provider-id>"; exit 1; }

  if ! jq -e --arg id "$provider_id" '.providers[$id]' "$REGISTRY" &>/dev/null; then
    echo -e "${RED}Provider '$provider_id' not found.${NC}"
    exit 1
  fi

  local tmp
  tmp=$(mktemp)
  jq --arg id "$provider_id" '
    .providers |= del(.[$id]) |
    .routing |= with_entries(.value |= [.[] | select(startswith($id + "/") | not)])
  ' "$REGISTRY" > "$tmp" && mv "$tmp" "$REGISTRY"

  echo -e "${GREEN}✓${NC} Provider '$provider_id' removed."
}

# ─── Add model to existing provider ──────────────────────────────────────────
cmd_add_model() {
  local provider_id="${1:-}"
  local model_id="${2:-}"
  [ -z "$provider_id" ] || [ -z "$model_id" ] && { echo "Usage: arka providers add-model <provider-id> <model-id> [--type image|video|text] [--description \"...\"]"; exit 1; }

  if ! jq -e --arg id "$provider_id" '.providers[$id]' "$REGISTRY" &>/dev/null; then
    echo -e "${RED}Provider '$provider_id' not found.${NC}"
    exit 1
  fi

  shift 2
  local model_type="text"
  local description=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --type) model_type="$2"; shift 2 ;;
      --description) description="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  [ -z "$description" ] && description="$model_id"

  local tmp
  tmp=$(mktemp)
  jq --arg pid "$provider_id" \
     --arg mid "$model_id" \
     --arg type "$model_type" \
     --arg desc "$description" \
     '.providers[$pid].models[$mid] = {type: $type, description: $desc}' \
     "$REGISTRY" > "$tmp" && mv "$tmp" "$REGISTRY"

  echo -e "${GREEN}✓${NC} Model '$model_id' ($model_type) added to '$provider_id'."
}

# ─── Add API key ─────────────────────────────────────────────────────────────
cmd_add_key() {
  local var_name="${1:-}"
  [ -z "$var_name" ] && { echo "Usage: arka providers add-key <ENV_VAR_NAME>"; exit 1; }

  mkdir -p "$(dirname "$ENV_FILE")"

  if is_key_configured "$var_name"; then
    echo -e "${GREEN}✓${NC} $var_name is already configured."
    read -rp "  Overwrite? (y/N): " confirm
    [ "$confirm" != "y" ] && [ "$confirm" != "Y" ] && exit 0
  fi

  read -rp "  Value for $var_name: " value
  [ -z "$value" ] && { echo "Skipped."; exit 0; }

  if grep -q "^export $var_name=" "$ENV_FILE" 2>/dev/null; then
    local tmp
    tmp=$(mktemp)
    sed "s|^export $var_name=.*|export $var_name=\"$value\"|" "$ENV_FILE" > "$tmp" && mv "$tmp" "$ENV_FILE"
  else
    echo "export $var_name=\"$value\"" >> "$ENV_FILE"
  fi

  echo -e "${GREEN}✓${NC} $var_name saved to $ENV_FILE"
  echo -e "  Run ${CYAN}source ~/.zshrc${NC} to load."
}

# ─── Show routing chains ─────────────────────────────────────────────────────
cmd_routing() {
  echo ""
  echo -e "${CYAN}═══ AI Provider Routing Chains ═══${NC}"
  echo ""

  local chains
  chains=$(jq -r '.routing | to_entries[] | .key' "$REGISTRY")

  for chain in $chains; do
    echo -e "  ${BOLD}$chain:${NC}"
    jq -r --arg chain "$chain" '.routing[$chain][]' "$REGISTRY" | while IFS= read -r model_ref; do
      local provider_id="${model_ref%%/*}"
      local model_id="${model_ref#*/}"
      local auth_env
      auth_env=$(jq -r --arg id "$provider_id" '.providers[$id].auth_env // "?"' "$REGISTRY")
      if is_key_configured "$auth_env"; then
        echo -e "    ${GREEN}●${NC} $model_ref"
      else
        echo -e "    ${RED}○${NC} $model_ref (${YELLOW}no key${NC})"
      fi
    done
    echo ""
  done
}

# ─── JSON output ──────────────────────────────────────────────────────────────
cmd_json() {
  # Enrich with configured status
  jq --arg env_file "$ENV_FILE" '
    . as $reg |
    .providers | to_entries | map(
      .value.configured = (
        .value.auth_env as $env |
        (env[$env] // "") | length >= 8
      )
    ) | from_entries |
    $reg | .providers = .
  ' "$REGISTRY" 2>/dev/null || cat "$REGISTRY"
}

# ─── Main ─────────────────────────────────────────────────────────────────────
case "${1:-}" in
  add)
    shift
    cmd_add "$@"
    ;;
  remove)
    shift
    cmd_remove "$@"
    ;;
  add-model)
    shift
    cmd_add_model "$@"
    ;;
  add-key)
    shift
    cmd_add_key "$@"
    ;;
  routing)
    cmd_routing
    ;;
  --json)
    cmd_json
    ;;
  *)
    cmd_list
    ;;
esac
