#!/usr/bin/env bash
# ============================================================================
# ARKA OS вҖ” CLI Wrapper
# Usage: arka [command] [args...]
# ============================================================================
set -e

command -v claude &>/dev/null || { echo "Error: Claude Code CLI not found."; exit 1; }

ARKA_OS="${ARKA_OS:-$HOME/.claude/skills/arka}"
[ -d "$ARKA_OS" ] || { echo "Error: ARKA OS not installed. Run: bash install.sh"; exit 1; }

# Run version check (silent on errors)
bash "$ARKA_OS/version-check.sh" 2>/dev/null || true

# Generate dynamic system prompt from user profile
SYSTEM_PROMPT=$(bash "$ARKA_OS/system-prompt.sh" 2>/dev/null || echo "")

# в”Җв”Җв”Җ ARKA OS Banner в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
show_banner() {
    local C='\033[0;36m'   # cyan
    local G='\033[0;32m'   # green
    local Y='\033[1;33m'   # yellow
    local N='\033[0m'      # reset
    local VERSION
    VERSION=$(cat "$ARKA_OS/VERSION" 2>/dev/null || echo "?")

    # Read user name from profile
    local USER_NAME=""
    if [ -f "$HOME/.arka-os/profile.json" ] && command -v jq &>/dev/null; then
        USER_NAME=$(jq -r '.user_name // ""' "$HOME/.arka-os/profile.json" 2>/dev/null)
    fi

    echo ""
    echo -e "${C}    в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—${N}"
    echo -e "${C}    в•‘${N}                                                          ${C}в•‘${N}"
    echo -e "${C}    в•‘${N}   ${G} в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—${N}   ${C}в•‘${N}"
    echo -e "${C}    в•‘${N}   ${G}в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ${N}   ${C}в•‘${N}"
    echo -e "${C}    в•‘${N}   ${G}в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—${N}   ${C}в•‘${N}"
    echo -e "${C}    в•‘${N}   ${G}в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘${N}   ${C}в•‘${N}"
    echo -e "${C}    в•‘${N}   ${G}в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘${N}   ${C}в•‘${N}"
    echo -e "${C}    в•‘${N}   ${G}в•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қ${N}   ${C}в•‘${N}"
    echo -e "${C}    в•‘${N}                                                          ${C}в•‘${N}"
    echo -e "${C}    в•‘${N}   ${Y}WizardingCode Company OS${N}  v${VERSION}                     ${C}в•‘${N}"
    if [ -n "$USER_NAME" ]; then
    echo -e "${C}    в•‘${N}   Welcome back, ${G}${USER_NAME}${N}!                                ${C}в•‘${N}"
    fi
    echo -e "${C}    в•‘${N}                                                          ${C}в•‘${N}"
    echo -e "${C}    в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ${N}"
    echo ""
}

case "${1:-}" in
  skill)
    shift
    bash "$HOME/.local/bin/arka-skill" "$@"
    exit $?
    ;;
  update)
    cd "$(cat "$ARKA_OS/.repo-path")" && git pull && bash install.sh
    exit $?
    ;;
  --version|-v)
    cat "$ARKA_OS/VERSION"
    exit 0
    ;;
  doctor)
    shift
    bash "$HOME/.local/bin/arka-doctor" "$@"
    exit $?
    ;;
  gotchas)
    shift
    GOTCHAS_FILE="$HOME/.arka-os/gotchas.json"
    case "${1:-}" in
      clear)
        echo '[]' > "$GOTCHAS_FILE"
        echo "Gotchas cleared."
        ;;
      --json)
        if [ -f "$GOTCHAS_FILE" ]; then
          cat "$GOTCHAS_FILE"
        else
          echo '[]'
        fi
        ;;
      *)
        if [ ! -f "$GOTCHAS_FILE" ] || [ "$(jq 'length' "$GOTCHAS_FILE" 2>/dev/null)" = "0" ]; then
          echo "No gotchas recorded yet."
          exit 0
        fi
        echo ""
        echo -e "\033[0;36mв•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—\033[0m"
        echo -e "\033[0;36mв•‘\033[0m  \033[1mARKA OS Gotchas\033[0m вҖ” Recurring Error Patterns      \033[0;36mв•‘\033[0m"
        echo -e "\033[0;36mв•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ\033[0m"
        echo ""
        jq -r '.[:10] | to_entries[] | "  \(.key + 1). [\(.value.category)] (Г—\(.value.count)) \(.value.pattern)\n     First: \(.value.first_seen) | Last: \(.value.last_seen)\n     Projects: \(.value.projects | join(", "))\n"' "$GOTCHAS_FILE" 2>/dev/null
        TOTAL=$(jq 'length' "$GOTCHAS_FILE" 2>/dev/null || echo "0")
        echo "  Total: $TOTAL gotcha(s) tracked"
        echo ""
        ;;
    esac
    exit 0
    ;;
  metrics)
    METRICS_FILE="$HOME/.arka-os/hook-metrics.json"
    if [ ! -f "$METRICS_FILE" ] || [ "$(jq 'length' "$METRICS_FILE" 2>/dev/null)" = "0" ]; then
      echo "No hook metrics recorded yet."
      exit 0
    fi
    echo ""
    echo -e "\033[0;36mв•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—\033[0m"
    echo -e "\033[0;36mв•‘\033[0m  \033[1mARKA OS Hook Metrics\033[0m вҖ” Last 24h               \033[0;36mв•‘\033[0m"
    echo -e "\033[0;36mв•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ\033[0m"
    echo ""
    CUTOFF=$(date -u -v-24H +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u -d '24 hours ago' +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "1970-01-01T00:00:00Z")
    jq -r --arg cutoff "$CUTOFF" '
      [.[] | select(.timestamp >= $cutoff)] | group_by(.hook) | .[] |
      {
        hook: .[0].hook,
        count: length,
        avg: ([.[].duration_ms] | add / length | floor),
        p95: ([.[].duration_ms] | sort | .[length * 95 / 100 | floor] // 0),
        max: ([.[].duration_ms] | max)
      } |
      "  \(.hook)\n    Count: \(.count)  Avg: \(.avg)ms  P95: \(.p95)ms  Max: \(.max)ms"
    ' "$METRICS_FILE" 2>/dev/null
    echo ""
    TOTAL=$(jq 'length' "$METRICS_FILE" 2>/dev/null || echo "0")
    echo "  Total entries: $TOTAL (keeps last 500)"
    echo ""
    exit 0
    ;;
  commands|registry)
    shift
    REPO_DIR="$(cat "$ARKA_OS/.repo-path" 2>/dev/null)"
    REGISTRY="$REPO_DIR/knowledge/commands-registry.json"
    case "${1:-}" in
      rebuild)
        bash "$REPO_DIR/bin/arka-registry-gen"
        echo "Registry rebuilt: $(jq '._meta.total_commands' "$REGISTRY") commands."
        ;;
      --json)
        [ -f "$REGISTRY" ] && cat "$REGISTRY" || echo '{"commands":[]}'
        ;;
      *)
        if [ ! -f "$REGISTRY" ]; then
          echo "Registry not found. Run: arka commands rebuild"
          exit 1
        fi
        echo ""
        echo -e "\033[0;36mв•җв•җв•җ ARKA OS вҖ” Available Commands в•җв•җв•җ\033[0m"
        echo ""
        jq -r '.commands | group_by(.department) | .[] |
          "  \u001b[1;33m\(.[0].department | ascii_upcase)\u001b[0m\n" +
          ([.[] | "    \(.command)\t\(.description)"] | join("\n")) + "\n"
        ' "$REGISTRY" 2>/dev/null
        TOTAL=$(jq '._meta.total_commands' "$REGISTRY" 2>/dev/null || echo "?")
        echo -e "  Total: $TOTAL commands"
        echo -e "  Tip: Just describe what you need вҖ” no need to memorize commands!"
        echo ""
        ;;
    esac
    exit 0
    ;;
  providers)
    shift
    REPO_DIR="$(cat "$ARKA_OS/.repo-path" 2>/dev/null)"
    bash "$REPO_DIR/bin/arka-providers" "$@"
    exit $?
    ;;
  team-balance)
    REPO_DIR="$(cat "$ARKA_OS/.repo-path" 2>/dev/null)"
    bash "$REPO_DIR/config/disc-team-validator.sh"
    exit $?
    ;;
  test)
    shift
    if command -v bats &>/dev/null; then
      REPO_DIR="$(cat "$ARKA_OS/.repo-path" 2>/dev/null)"
      bats "$REPO_DIR/tests/" "$@"
    else
      echo "Error: bats-core not installed. Install: brew install bats-core"
      exit 1
    fi
    exit $?
    ;;
  kb)
    shift
    SCRIPTS_DIR="$HOME/.claude/skills/arka-knowledge/scripts"
    # Fallback to repo scripts location
    if [ ! -d "$SCRIPTS_DIR" ]; then
        REPO_DIR="$(cat "$ARKA_OS/.repo-path" 2>/dev/null)"
        SCRIPTS_DIR="$REPO_DIR/departments/kb/scripts"
    fi
    case "${1:-}" in
      queue)        bash "$SCRIPTS_DIR/kb-status.sh" "${@:2}" ;;
      status)       bash "$SCRIPTS_DIR/kb-status.sh" "${@:2}" ;;
      capabilities) bash "$SCRIPTS_DIR/kb-check-capabilities.sh" ;;
      cleanup)      bash "$SCRIPTS_DIR/kb-cleanup.sh" "${@:2}" ;;
      *)            claude "/kb $*" ;;
    esac
    exit $?
    ;;
  *)
    # Show branded banner for interactive sessions (no arguments)
    if [ $# -eq 0 ]; then
        show_banner
    fi

    if [ -n "$SYSTEM_PROMPT" ]; then
      if [ $# -gt 0 ]; then
        claude --append-system-prompt "$SYSTEM_PROMPT" "$*"
      else
        claude --append-system-prompt "$SYSTEM_PROMPT"
      fi
    else
      if [ $# -gt 0 ]; then
        claude "$*"
      else
        claude
      fi
    fi
    ;;
esac
