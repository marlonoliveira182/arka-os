{
  "statusLine": {
    "type": "command",
    "command": "{{STATUSLINE_PATH}}",
    "padding": 2
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/user-prompt-submit.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/pre-compact.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
