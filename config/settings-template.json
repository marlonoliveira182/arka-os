{
  "statusLine": {
    "type": "command",
    "command": "{{STATUSLINE_PATH}}",
    "padding": 2
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/user-prompt-submit.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/pre-compact.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/post-tool-use.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/cwd-changed.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOOKS_DIR}}/agent-provision.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
