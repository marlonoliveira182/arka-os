{
  "_meta": {
    "description": "ARKA OS — Central MCP Registry",
    "format": "Claude Code .mcp.json compatible",
    "updated": "2026-03-15"
  },
  "mcpServers": {
    "arka-prompts": {
      "command": "uv",
      "args": ["--directory", "{home}/.claude/skills/arka/mcp-server", "run", "server.py"],
      "category": "base",
      "description": "ARKA OS department commands as MCP prompts (Claude Code + Claude Desktop)",
      "required_env": []
    },
    "obsidian": {
      "command": "npx",
      "args": ["@bitbonsai/mcpvault@latest", "{home}/Documents/Personal"],
      "category": "base",
      "description": "Obsidian vault integration: read/write notes, personas, knowledge",
      "required_env": []
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "category": "base",
      "description": "Up-to-date library and framework documentation",
      "required_env": []
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "category": "base",
      "description": "Browser automation and testing",
      "required_env": []
    },
    "memory-bank": {
      "command": "npx",
      "args": ["-y", "@allpepper/memory-bank-mcp"],
      "env": {
        "MEMORY_BANK_ROOT": "{home}/memory-bank"
      },
      "category": "base",
      "description": "Persistent memory across sessions",
      "required_env": ["MEMORY_BANK_ROOT"]
    },
    "clickup": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.clickup.com/mcp"],
      "env": {
        "CLICKUP_API_KEY": "${CLICKUP_API_KEY}",
        "CLICKUP_TEAM_ID": "${CLICKUP_TEAM_ID}"
      },
      "category": "base",
      "description": "Task management and project tracking",
      "required_env": ["CLICKUP_API_KEY", "CLICKUP_TEAM_ID"]
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      },
      "category": "base",
      "description": "Web crawling and scraping",
      "required_env": ["FIRECRAWL_API_KEY"]
    },
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp",
      "category": "base",
      "description": "Error tracking and performance monitoring",
      "required_env": []
    },
    "gh-grep": {
      "type": "http",
      "url": "https://mcp.grep.app",
      "category": "base",
      "description": "Search across GitHub repositories",
      "required_env": []
    },
    "laravel-boost": {
      "command": "php",
      "args": ["artisan", "boost:mcp"],
      "category": "laravel",
      "description": "Laravel Boost: AI-powered Laravel development tools",
      "required_env": []
    },
    "serena": {
      "command": "uvx",
      "args": ["--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server", "--context", "ide-assistant", "--project", "{cwd}"],
      "category": "laravel",
      "description": "Code intelligence: type-aware code analysis and refactoring",
      "required_env": []
    },
    "nuxt-ui": {
      "type": "http",
      "url": "https://ui.nuxt.com/mcp",
      "category": "nuxt",
      "description": "Nuxt UI component library documentation and examples",
      "required_env": []
    },
    "nuxt": {
      "type": "http",
      "url": "https://nuxt.com/mcp",
      "category": "nuxt",
      "description": "Nuxt framework documentation and best practices",
      "required_env": []
    },
    "mirakl": {
      "type": "http",
      "url": "https://developer.mirakl.com/mcp",
      "category": "ecommerce",
      "description": "Mirakl marketplace API integration",
      "required_env": []
    },
    "next-devtools": {
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"],
      "category": "react",
      "description": "Next.js DevTools: debugging and development assistance",
      "required_env": []
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp",
      "category": "base",
      "description": "Supabase database management and APIs",
      "required_env": []
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "mcp-postgres-server"],
      "env": {
        "PG_HOST": "${PG_HOST}",
        "PG_PORT": "${PG_PORT}",
        "PG_USER": "${PG_USER}",
        "PG_PASSWORD": "${PG_PASSWORD}",
        "PG_DATABASE": "${PG_DATABASE}"
      },
      "category": "base",
      "description": "PostgreSQL direct database access",
      "required_env": ["PG_HOST", "PG_PORT", "PG_USER", "PG_PASSWORD", "PG_DATABASE"]
    },
    "shopify-dev": {
      "command": "npx",
      "args": ["-y", "@shopify/dev-mcp@latest"],
      "category": "ecommerce",
      "description": "Shopify development tools and API access",
      "required_env": []
    },
    "slack": {
      "type": "http",
      "url": "https://mcp.slack.com/mcp",
      "category": "comms",
      "description": "Slack messaging integration (OAuth)",
      "required_env": []
    },
    "discord": {
      "command": "npx",
      "args": ["-y", "discord-mcp"],
      "env": {
        "DISCORD_TOKEN": "${DISCORD_TOKEN}"
      },
      "category": "comms",
      "description": "Discord bot and messaging integration",
      "required_env": ["DISCORD_TOKEN"]
    },
    "whatsapp": {
      "command": "npx",
      "args": ["-y", "whatsapp-mcp"],
      "env": {
        "WHATSAPP_API_TOKEN": "${WHATSAPP_API_TOKEN}",
        "WHATSAPP_PHONE_ID": "${WHATSAPP_PHONE_ID}"
      },
      "category": "comms",
      "description": "WhatsApp Business API messaging",
      "required_env": ["WHATSAPP_API_TOKEN", "WHATSAPP_PHONE_ID"]
    },
    "teams": {
      "command": "npx",
      "args": ["-y", "teams-mcp"],
      "env": {
        "TEAMS_APP_ID": "${TEAMS_APP_ID}",
        "TEAMS_APP_SECRET": "${TEAMS_APP_SECRET}"
      },
      "category": "comms",
      "description": "Microsoft Teams messaging integration",
      "required_env": ["TEAMS_APP_ID", "TEAMS_APP_SECRET"]
    },
    "canva": {
      "type": "http",
      "url": "https://mcp.canva.com/mcp",
      "category": "brand",
      "description": "Canva design platform: create, edit, export designs, and manage brand kits",
      "required_env": []
    }
  }
}
